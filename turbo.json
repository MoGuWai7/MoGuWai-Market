{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env.example",
    "pnpm-workspace.yaml",
    "turbo.json"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "dist/**",
        "build/**",
        ".expo/**"
      ],
      "env": [
        "SUPABASE_SERVICE_ROLE_KEY",
        "VISIT_LOG_SECRET_KEY",
        "NEXT_PUBLIC_ADMIN_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "format": {
      "cache": false
    }
  }
}
